{
  "name": "sa-tax-platform",
  "version": "0.1.0",
  "description": "TaxOps ZA desktop platform for South African tax compliance and SARS workflow management.",
  "author": "TaxOps ZA",
  "private": true,
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "desktop:dev": "node desktop/run-desktop-dev.cjs",
    "desktop:bundle": "npm run build && node desktop/prepare-standalone.cjs",
    "desktop:start": "node desktop/run-desktop-prod.cjs",
    "desktop:dist": "node desktop/run-desktop-dist.cjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.13",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "electron": "^38.3.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.0.1",
    "prisma": "^6.16.2",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "za.taxops.desktop",
    "productName": "TaxOps ZA",
    "asar": true,
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "desktop/main.cjs",
      "desktop/browser-session.cjs",
      "desktop/file-actions.cjs",
      "desktop/golden-demo-restore.cjs",
      "desktop/golden-demo-bundle.json",
      "desktop/preload.cjs",
      "desktop/port-utils.cjs",
      "desktop/runtime-paths.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next/standalone"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "TaxOps-ZA-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
